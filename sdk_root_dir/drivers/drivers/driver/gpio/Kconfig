config GPIO_SUPPORT_LPM
    bool
    prompt "GPIO support low power mode, supend and reusme."
    default y
    depends on DRIVER_SUPPORT_GPIO

config GPIO_SELECT_CORE
    bool
    prompt "GPIO support choose to select core."
    default n
    depends on DRIVER_SUPPORT_GPIO