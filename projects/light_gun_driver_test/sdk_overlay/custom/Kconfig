    int "Rumble PWM group id"
    default 0
    range 0 5
    help
        Used on PWM V151 path. The selected rumble PWM channel will be attached to this group before start.

config LIGHT_GUN_RUMBLE_PWM_PIN
    int "Rumble PWM pin"
    default 1
    range 0 31

config LIGHT_GUN_RUMBLE_PWM_PIN_MODE
    int "Rumble PWM pin mode"
    default 42
    help
        GPIO1 接 PWM1 时，优先使用 42 做正向输出验证。
        41/43/45... 这类值在当前芯片头文件注释里带有 COMP 含义，
        更像互补输出脚，不适合先拿来做基础波形联调。

choice LIGHT_GUN_RUMBLE_CASE
