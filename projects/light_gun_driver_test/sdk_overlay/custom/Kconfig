menu "IR Sensor Test Config"

config LIGHT_GUN_IR_I2C_BUS_ID
    int "IR I2C bus id"
    default 0
    range 0 1
    help
        默认使用 I2C0。

config LIGHT_GUN_IR_SCL_PIN
    int "IR I2C SCL GPIO"
    default 25
    range 0 31

config LIGHT_GUN_IR_SDA_PIN
    int "IR I2C SDA GPIO"
    default 26
    range 0 31

config LIGHT_GUN_IR_SCL_PIN_MODE
    int "IR I2C SCL pin mode"
    default 26
    help
        TR531x 上 I2C0 CLK 的默认 pinmux 枚举值为 26。

config LIGHT_GUN_IR_SDA_PIN_MODE
    int "IR I2C SDA pin mode"
    default 27
    help
        TR531x 上 I2C0 DATA 的默认 pinmux 枚举值为 27。

config LIGHT_GUN_IR_I2C_ADDR
    hex "IR sensor I2C address"
    default 0x58
    help
        Wii IR Camera 兼容模块通常使用 0x58。

config LIGHT_GUN_IR_I2C_BAUDRATE
    int "IR I2C baudrate"
    default 200000
    range 100000 1000000

config LIGHT_GUN_IR_POLL_MS
    int "IR poll interval ms"
    default 20
    range 5 1000
    help
        软件定时器轮询周期。20ms 便于先稳定抓日志。

config LIGHT_GUN_IR_REPLAY_STEP_MS
    int "IR replay step interval ms"
    default 300
    range 50 5000

config LIGHT_GUN_IR_ATOMIC_RETRY
    int "IR atomic read retry count"
    default 2
    range 0 2
    help
        对齐 OpenFIRE/DFRobot 的双帧稳定读取思路。

config LIGHT_GUN_IR_SENSITIVITY
    int "IR sensor sensitivity"
    default 0
    range 0 2
    help
        0=default, 1=high, 2=max。

choice LIGHT_GUN_IR_CASE
    prompt "IR test mode"
    default LIGHT_GUN_IR_CASE_SOLVE_LIVE
    help
        选择当前要验证的 IR 测试流程。

config LIGHT_GUN_IR_CASE_INIT_ONLY
    bool "Init only"

config LIGHT_GUN_IR_CASE_RAW_STREAM
    bool "Raw point stream"

config LIGHT_GUN_IR_CASE_SOLVE_LIVE
    bool "Live solve"

config LIGHT_GUN_IR_CASE_SOLVE_REPLAY
    bool "Replay solve"

endchoice

config LIGHT_GUN_IR_SCREEN_WIDTH
    int "Solved screen width"
    default 1920
    range 320 8192

config LIGHT_GUN_IR_SCREEN_HEIGHT
    int "Solved screen height"
    default 1080
    range 240 8192

config LIGHT_GUN_IR_INVERT_X
    bool "Invert solved X axis"
    default n
    help
        当 IR 相机安装方向与枪体水平镜像时打开。

config LIGHT_GUN_IR_INVERT_Y
    bool "Invert solved Y axis"
    default n
    help
        仅在上下方向也反了时再打开。

config LIGHT_GUN_IR_CAM_MIN_X
    int "Camera min X"
    default 0
    range 0 1023

config LIGHT_GUN_IR_CAM_MAX_X
    int "Camera max X"
    default 1023
    range 1 1023

config LIGHT_GUN_IR_CAM_MIN_Y
    int "Camera min Y"
    default 0
    range 0 767

config LIGHT_GUN_IR_CAM_MAX_Y
    int "Camera max Y"
    default 767
    range 1 767

config LIGHT_GUN_IR_SMOOTH_PERCENT
    int "IR smoothing percent"
    default 35
    range 0 95
    help
        0 表示不过滤，值越大表示越偏向历史值。

config LIGHT_GUN_IR_MIN_POINTS_FOR_SOLVE
    int "Minimum visible points for solve"
    default 2
    range 1 4
    help
        推荐保持 2，表示至少看到左右两个参考点才算稳定解算。

config LIGHT_GUN_IR_COMPACT_LOG
    bool "Enable IR compact debug log"
    default y
    help
        打开后不会每一帧都刷完整日志，而是按状态变化或抽样打印，
        更适合边联调边看串口。

config LIGHT_GUN_IR_LOG_EVERY_N
    int "IR compact log every N polls"
    default 10
    range 1 1000
    help
        仅在 compact log 打开时生效。

config LIGHT_GUN_IR_SINGLE_POINT_DEGRADE
    bool "Enable single-point degraded solve"
    default y
    help
        当只有 1 个 IR 点时，允许退化成“单点直接映射”，
        这样可以继续出一个近似坐标，方便先联调 USB 鼠标链路。

endmenu

menu "USB Sim Test Config"

choice LIGHT_GUN_USB_DEVICE_MODE
    prompt "USB device mode"
    default LIGHT_GUN_USB_DEVICE_MODE_HID
    help
        选择当前测试工程对外枚举的 USB 设备类型。

config LIGHT_GUN_USB_DEVICE_MODE_HID
    bool "HID only (keyboard + mouse)"
    select DRIVERS_USB_HID_GADGET
    select DRIVERS_USB_HID_FUNC_INTERFACE
    select DRIVERS_USB_COMPOSITE_GADGET
    help
        保持当前行为，只枚举 HID 键盘 + 鼠标。

config LIGHT_GUN_USB_DEVICE_MODE_ACM_HID
    bool "CDC ACM + HID composite"
    select DRIVERS_USB_SERIAL_GADGET
    select DRIVERS_USB_HID_GADGET
    select DRIVERS_USB_HID_FUNC_INTERFACE
    select DRIVERS_USB_ACM_HID_GADGET
    select DRIVERS_USB_COMPOSITE_GADGET
    help
        额外枚举一个 CDC ACM 串口，同时保留 HID 键盘 + 鼠标。

endchoice

config LIGHT_GUN_USB_SIM_FAKE_IR
    bool "Enable fake IR script"
    default y
    help
        启用固定坐标脚本，模拟 IR 识别结果。

config LIGHT_GUN_USB_SIM_FAKE_LED
    bool "Enable fake LED log script"
    default y
    help
        启用 LEDX ON/OFF 串口日志脚本。

config LIGHT_GUN_USB_SIM_SCRIPT_MOUSE_MOVE
    bool "Enable scripted mouse move"
    default y
    help
        启用脚本化鼠标移动验证。

config LIGHT_GUN_USB_SIM_SCRIPT_MOUSE_CLICK
    bool "Enable scripted mouse click"
    default y
    help
        启用脚本化鼠标按键点击验证。

config LIGHT_GUN_USB_SIM_SCRIPT_KEYBOARD
    bool "Enable scripted keyboard report"
    default y
    help
        启用脚本化键盘 Enter / Esc 上报验证。

config LIGHT_GUN_USB_SIM_GPIO_PASSTHROUGH
    bool "Enable physical button passthrough"
    default y
    help
        启用物理 GPIO 按键透传测试。

config LIGHT_GUN_USB_SIM_TRIGGER_REF
    bool "Enable OpenFIRE-style trigger reference"
    default y
    help
        启用 onscreen / offscreen trigger 参考逻辑。
        这个开关打开后，脚本或定时器会驱动屏内 / 屏外状态切换，
        Trigger 键会按当前状态决定是发左键、右键还是抑制。

config LIGHT_GUN_USB_SIM_USE_IR_LIVE_MOUSE
    bool "Use live IR solve to drive USB mouse"
    default n
    help
        打开后，USB 鼠标移动和屏内/屏外状态由真实 IR 解算结果驱动。
        为避免两套鼠标业务互相打架，脚本化 mouse move / mouse click /
        fake IR / trigger reference 会在运行时自动停用。

choice LIGHT_GUN_USB_OFFSCREEN_MODE
    prompt "Trigger offscreen behavior"
    default LIGHT_GUN_USB_OFFSCREEN_MODE_RIGHT_CLICK
    help
        用来模拟 OpenFIRE 的“屏外开火”行为。

config LIGHT_GUN_USB_OFFSCREEN_MODE_DISABLE
    bool "Offscreen trigger suppressed"

config LIGHT_GUN_USB_OFFSCREEN_MODE_RIGHT_CLICK
    bool "Offscreen trigger -> right click"

endchoice

