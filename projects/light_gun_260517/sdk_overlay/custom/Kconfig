config LIGHT_GUN_260517_IR_ENABLE_REMAP
    bool "Enable IR remap by calibration/profile"
    default n
    help
        打开后根据 center 和 top/bottom/left/right 校准结果对 IR 原始坐标做二次映射。
        调试左右异常时建议先关闭，直接走原始线性映射链路。

config LIGHT_GUN_260517_IR_ENABLE_SPRING
    bool "Enable IR spring filter"
    default n
    help
        打开后对坐标跳变做缓冲跟随。
        调试方向不对或拖尾时建议先关闭。

config LIGHT_GUN_260517_IR_ENABLE_SPRING_X
    bool "Enable IR spring filter on X axis"
    default n
    depends on LIGHT_GUN_260517_IR_ENABLE_SPRING
    help
        单独控制 X 轴是否启用 spring。
        左右移动异常时建议先关闭，只保留 Y 轴 spring 做对比。

config LIGHT_GUN_260517_IR_ENABLE_SPRING_Y
    bool "Enable IR spring filter on Y axis"
    default y
    depends on LIGHT_GUN_260517_IR_ENABLE_SPRING
    help
        单独控制 Y 轴是否启用 spring。
        如果只想验证上下方向的缓冲效果，可以只打开这一项。

config LIGHT_GUN_260517_IR_ENABLE_AVERAGE
    bool "Enable IR average filter by run mode"
    default n
    help
        打开后才会应用 Normal/Average/Average2 三种运行模式的均值滤波。
        关闭时直接输出当前映射值，便于先排查基础方向问题。

